// HP Exam Achievers - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  SINGLE_CORRECT
  MULTIPLE_CORRECT
  TRUE_FALSE
  INTEGER
  PARAGRAPH
  MATCH_FOLLOWING
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  TIMED_OUT
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          Role      @default(STUDENT)
  isActive      Boolean   @default(true)
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  lastLoginIp   String?
  lastDevice    String?
  
  // Relations
  teacherProfile  TeacherProfile?
  studentProfile  StudentProfile?
  createdExams    Exam[]          @relation("ExamCreator")
  sessions        Session[]
  notifications   Notification[]
  
  @@index([email])
  @@index([phone])
}

model TeacherProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization  String?
  subjects      String[]
  bio           String?
  totalStudents Int     @default(0)
  totalExams    Int     @default(0)
}

model StudentProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId       String?
  studentCode     String    @unique  // e.g. HP-R001
  dailyStreak     Int       @default(0)
  lastStreakDate  DateTime?
  totalPoints     Int       @default(0)
  rank            Int?
  
  // Relations
  examAssignments ExamAssignment[]
  attempts        ExamAttempt[]
  bookmarks       Bookmark[]
  achievements    Achievement[]
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String?
  color       String?
  isActive    Boolean @default(true)
  exams       Exam[]
}

model QuestionBank {
  id          String   @id @default(cuid())
  teacherId   String
  name        String
  subject     String
  chapter     String?
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  questions   Question[]
}

model Question {
  id              String       @id @default(cuid())
  bankId          String?
  bank            QuestionBank? @relation(fields: [bankId], references: [id])
  teacherId       String
  type            QuestionType @default(SINGLE_CORRECT)
  difficulty      Difficulty   @default(MEDIUM)
  subject         String
  chapter         String?
  tags            String[]
  
  // Question content
  content         String       // HTML/Markdown
  imageUrl        String?
  explanation     String?
  explanationImg  String?
  
  // Options (JSON)
  options         Json?        // [{id, text, imageUrl, isCorrect}]
  correctAnswer   String?      // For integer type
  matchPairs      Json?        // [{left, right}]
  
  // Marks
  marks           Float        @default(1)
  negativeMarks   Float        @default(0)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  
  examQuestions   ExamQuestion[]
}

model Exam {
  id                  String     @id @default(cuid())
  creatorId           String
  creator             User       @relation("ExamCreator", fields: [creatorId], references: [id])
  categoryId          String?
  category            Category?  @relation(fields: [categoryId], references: [id])
  
  title               String
  examName            String?    // e.g. "HPPSC", "HP Police"
  description         String?
  instructions        String?
  instructionsPdfUrl  String?
  
  // Settings
  duration            Int        // minutes
  totalMarks          Float
  passingMarks        Float?
  negativeMarking     Boolean    @default(false)
  negMarkValue        Float      @default(0.25)
  maxAttempts         Int        @default(1)
  
  // Scheduling
  status              ExamStatus @default(DRAFT)
  startDate           DateTime?
  endDate             DateTime?
  
  // Options
  randomizeQuestions  Boolean    @default(false)
  randomizeOptions    Boolean    @default(false)
  showResultImmediately Boolean  @default(true)
  showCorrectAnswers  Boolean    @default(true)
  leaderboardEnabled  Boolean    @default(true)
  isPasswordProtected Boolean    @default(false)
  password            String?
  
  // Stats
  totalAttempts       Int        @default(0)
  avgScore            Float?
  highestScore        Float?
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  
  // Relations
  questions           ExamQuestion[]
  assignments         ExamAssignment[]
  attempts            ExamAttempt[]
}

model ExamQuestion {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  order       Int
  marks       Float
  negMarks    Float    @default(0)
  
  @@unique([examId, questionId])
  @@index([examId])
}

model ExamAssignment {
  id              String         @id @default(cuid())
  examId          String
  exam            Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attemptsAllowed Int            @default(1)
  attemptsUsed    Int            @default(0)
  isActive        Boolean        @default(true)
  assignedAt      DateTime       @default(now())
  
  @@unique([examId, studentId])
}

model ExamAttempt {
  id              String        @id @default(cuid())
  examId          String
  exam            Exam          @relation(fields: [examId], references: [id])
  studentId       String
  student         StudentProfile @relation(fields: [studentId], references: [id])
  attemptNumber   Int
  
  status          AttemptStatus @default(IN_PROGRESS)
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  timeTaken       Int?          // seconds
  
  // Results
  score           Float?
  totalMarks      Float?
  correctCount    Int?
  wrongCount      Int?
  skippedCount    Int?
  accuracy        Float?
  percentage      Float?
  rank            Int?
  
  // Saved state (for auto-save)
  answers         Json          @default("{}")  // {questionId: answer}
  markedReview    String[]
  
  // Security
  ipAddress       String?
  userAgent       String?
  tabSwitches     Int           @default(0)
  fullscreenExits Int           @default(0)
  
  createdAt       DateTime      @default(now())
  
  // Relations
  questionResults QuestionResult[]
  
  @@index([examId])
  @@index([studentId])
}

model QuestionResult {
  id          String      @id @default(cuid())
  attemptId   String
  attempt     ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId  String
  answer      String?     // JSON for multiple correct
  isCorrect   Boolean     @default(false)
  isSkipped   Boolean     @default(false)
  marksObtained Float     @default(0)
  timeTaken   Int?        // seconds per question
  
  @@index([attemptId])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  
  @@index([token])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // exam_reminder, result, announcement, password_reset
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  
  @@index([userId])
}

model Bookmark {
  id         String         @id @default(cuid())
  studentId  String
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  questionId String
  note       String?
  createdAt  DateTime       @default(now())
  
  @@unique([studentId, questionId])
}

model Achievement {
  id          String         @id @default(cuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  type        String         // first_test, perfect_score, streak_7, etc.
  title       String
  description String
  iconUrl     String?
  earnedAt    DateTime       @default(now())
}

model Certificate {
  id          String   @id @default(cuid())
  attemptId   String   @unique
  studentName String
  examTitle   String
  score       Float
  percentage  Float
  issuedAt    DateTime @default(now())
  pdfUrl      String?
  verifyCode  String   @unique @default(cuid())
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float
  isPercent   Boolean  @default(true)
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SiteSettings {
  id            String  @id @default(cuid())
  key           String  @unique
  value         String
  description   String?
}
